      "parameters": {
        "jsCode": "// Process and categorize calendar events\nconst events = $input.all();\nconst now = new Date();\nconst todayStart = new Date(now.getFullYear(), now.getMonth(), now.getDate());\nconst todayEnd = new Date(todayStart.getTime() + 24 * 60 * 60 * 1000);\nconst tomorrowEnd = new Date(todayStart.getTime() + 48 * 60 * 60 * 1000);\n\nconst processedEvents = events.map(item => {\n  const event = item.json;\n  const startTime = new Date(event.start?.dateTime || event.start?.date);\n  const endTime = new Date(event.end?.dateTime || event.end?.date);\n  const isAllDay = !event.start?.dateTime;\n  \n  // Determine time category\n  let timeCategory = 'later';\n  if (startTime < todayEnd) timeCategory = 'today';\n  else if (startTime < tomorrowEnd) timeCategory = 'tomorrow';\n  \n  // Calculate meeting load (duration in hours)\n  const durationHours = (endTime - startTime) / (1000 * 60 * 60);\n  \n  // Identify meeting type and priority signals\n  const summary = (event.summary || '').toLowerCase();\n  const attendees = event.attendees || [];\n  const externalAttendees = attendees.filter(a => !a.email?.includes(event.organizer?.email?.split('@')[1] || ''));\n  \n  let meetingType = 'general';\n  let prioritySignal = 'normal';\n  \n  // Detect high-priority meeting types\n  if (summary.includes('board') || summary.includes('investor')) {\n    meetingType = 'board/investor';\n    prioritySignal = 'critical';\n  } else if (summary.includes('1:1') || summary.includes('one on one') || summary.includes('1-1')) {\n    meetingType = '1:1';\n    prioritySignal = 'high';\n  } else if (summary.includes('review') || summary.includes('decision')) {\n    meetingType = 'decision';\n    prioritySignal = 'high';\n  } else if (summary.includes('all hands') || summary.includes('town hall')) {\n    meetingType = 'company-wide';\n    prioritySignal = 'high';\n  } else if (summary.includes('deadline') || summary.includes('due')) {\n    meetingType = 'deadline';\n    prioritySignal = 'critical';\n  } else if (summary.includes('interview')) {\n    meetingType = 'interview';\n    prioritySignal = 'high';\n  } else if (externalAttendees.length > 0) {\n    meetingType = 'external';\n    prioritySignal = 'high';\n  } else if (summary.includes('standup') || summary.includes('sync')) {\n    meetingType = 'recurring';\n    prioritySignal = 'normal';\n  }\n  \n  return {\n    json: {\n      id: event.id,\n      title: event.summary || 'Untitled',\n      description: event.description || '',\n      startTime: startTime.toISOString(),\n      endTime: endTime.toISOString(),\n      startTimeFormatted: startTime.toLocaleString('en-US', {\n        weekday: 'short',\n        month: 'short',\n        day: 'numeric',\n        hour: 'numeric',\n        minute: '2-digit'\n      }),\n      timeCategory,\n      isAllDay,\n      durationHours: Math.round(durationHours * 10) / 10,\n      meetingType,\n      prioritySignal,\n      attendeeCount: attendees.length,\n      hasExternalAttendees: externalAttendees.length > 0,\n      location: event.location || '',\n      meetingLink: event.hangoutLink || event.conferenceData?.entryPoints?.[0]?.uri || '',\n      calendarLink: event.htmlLink\n    }\n  };\n});\n\n// Calculate today's meeting load\nconst todayEvents = processedEvents.filter(e => e.json.timeCategory === 'today');\nconst todayMeetingHours = todayEvents.reduce((sum, e) => sum + e.json.durationHours, 0);\nconst criticalMeetings = processedEvents.filter(e => e.json.prioritySignal === 'critical');\nconst highPriorityMeetings = processedEvents.filter(e => e.json.prioritySignal === 'high');\n\nreturn [{\n  json: {\n    events: processedEvents.map(e => e.json),\n    todayEvents: todayEvents.map(e => e.json),\n    summary: {\n      totalEvents: processedEvents.length,\n      todayCount: todayEvents.length,\n      todayMeetingHours: Math.round(todayMeetingHours * 10) / 10,\n      criticalCount: criticalMeetings.length,\n      highPriorityCount: highPriorityMeetings.length,\n      availableHours: Math.max(0, 8 - todayMeetingHours)\n    },\n    criticalMeetings: criticalMeetings.map(e => e.json),\n    highPriorityMeetings: highPriorityMeetings.map(e => e.json)\n  }\n}];"
      },
