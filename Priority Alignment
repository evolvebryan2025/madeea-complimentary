    {
      "parameters": {
        "jsCode": "// Consolidate all data for AI priority analysis\nconst items = $input.all();\nconst config = $('Set Configuration').first().json;\n\n// Extract processed data from each source\nlet calendarData = { events: [], todayEvents: [], summary: {}, criticalMeetings: [], highPriorityMeetings: [] };\nlet emailData = { emails: [], actionableEmails: [], summary: {}, criticalEmails: [], highPriorityEmails: [] };\nlet taskData = { tasks: [], summary: {}, overdueTasks: [], todayTasks: [], criticalTasks: [] };\n\nfor (const item of items) {\n  if (item.json.events) calendarData = item.json;\n  if (item.json.emails) emailData = item.json;\n  if (item.json.tasks) taskData = item.json;\n}\n\n// Build comprehensive context for AI\nconst context = {\n  executive: {\n    name: config.executiveName,\n    strategicGoals: config.strategicGoals,\n    priorityWeights: config.priorityWeights\n  },\n  \n  calendar: {\n    summary: calendarData.summary,\n    criticalMeetings: calendarData.criticalMeetings?.slice(0, 5) || [],\n    highPriorityMeetings: calendarData.highPriorityMeetings?.slice(0, 5) || [],\n    todaySchedule: calendarData.todayEvents?.slice(0, 10) || []\n  },\n  \n  emails: {\n    summary: emailData.summary,\n    criticalEmails: emailData.criticalEmails?.slice(0, 5) || [],\n    actionableEmails: emailData.actionableEmails?.slice(0, 8) || []\n  },\n  \n  tasks: {\n    summary: taskData.summary,\n    overdueTasks: taskData.overdueTasks?.slice(0, 5) || [],\n    todayTasks: taskData.todayTasks?.slice(0, 5) || [],\n    criticalTasks: taskData.criticalTasks?.slice(0, 5) || []\n  },\n  \n  // Overall health metrics\n  dayHealth: {\n    meetingLoad: calendarData.summary?.todayMeetingHours || 0,\n    availableFocusHours: calendarData.summary?.availableHours || 8,\n    pendingDecisions: (emailData.summary?.byCategory?.decisionNeeded || 0) + \n                      (taskData.tasks?.filter(t => t.category === 'decision').length || 0),\n    overdueItems: taskData.summary?.overdueCount || 0,\n    criticalItems: (calendarData.summary?.criticalCount || 0) + \n                   (emailData.summary?.criticalCount || 0) + \n                   (taskData.summary?.criticalCount || 0)\n  }\n};\n\nreturn [{ json: context }];"
      },
