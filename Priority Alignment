    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet aiOutput = '';\n\n// Extract AI response from OpenAI or similar nodes\nfor (const item of items) {\n  if (typeof item.json.output === 'string') aiOutput = item.json.output;\n  else if (typeof item.json.content === 'string') aiOutput = item.json.content;\n  else if (typeof item.json.message?.content === 'string') aiOutput = item.json.message.content;\n}\n\n// Fallback if non-string\nif (typeof aiOutput !== 'string') {\n  aiOutput = JSON.stringify(aiOutput, null, 2);\n}\n\n// Strip any old HTML tags to prevent recursive growth\naiOutput = aiOutput.replace(/<[^>]*>/g, '');\n\n// Get context and config\nconst context = $('Build AI Context').first().json;\nconst config = $('Set Configuration').first().json;\n\n// Format current time\nconst now = new Date();\nconst dateStr = now.toLocaleDateString('en-US', {\n  weekday: 'long',\n  year: 'numeric',\n  month: 'long',\n  day: 'numeric'\n});\nconst timeStr = now.toLocaleTimeString('en-US', {\n  hour: 'numeric',\n  minute: '2-digit'\n});\n\n// Generate plain text version\nconst textOutput = `\n╔══════════════════════════════════════════════════════════════════════════════╗\n║  🎯 EXECUTIVE PRIORITY ALIGNMENT                                             ║\n║  Daily Clarity. Zero Decision Fatigue.                                       ║\n╚══════════════════════════════════════════════════════════════════════════════╝\n\n📅 ${dateStr}\n⏰ Generated at ${timeStr}\n👤 ${config.executiveName}\n\n════════════════════════════════════════════════════════════════════════════════\n\n${aiOutput}\n\n════════════════════════════════════════════════════════════════════════════════\n\n📈 DATA SOURCES ANALYZED:\n• Calendar Events: ${context.calendar?.summary?.totalEvents || 0} (${context.calendar?.summary?.todayCount || 0} today)\n• Emails Processed: ${context.emails?.summary?.totalEmails || 0} (${context.emails?.summary?.actionableCount || 0} actionable)\n• Tasks Reviewed: ${context.tasks?.summary?.totalTasks || 0} (${context.tasks?.summary?.overdueCount || 0} overdue)\n\n────────────────────────────────────────────────────────────────────────────────\nGenerated by Executive Priority Alignment Automation™\n${new Date().toLocaleString()}\n────────────────────────────────────────────────────────────────────────────────\n`;\n\n// ✅ Safe markdown to HTML conversion\nfunction formatMarkdown(md) {\n  if (typeof md !== 'string') {\n    md = JSON.stringify(md, null, 2);\n  }\n\n  // Remove any HTML tags if present\n  md = md.replace(/<[^>]*>/g, '');\n\n  // Convert markdown to basic HTML\n  let html = md\n    .replace(/^### (.*$)/gim, '<h3>$1</h3>')\n    .replace(/^## (.*$)/gim, '<h2>$1</h2>')\n    .replace(/\\*\\*(.*?)\\*\\*/gim, '<strong>$1</strong>')\n    .replace(/^- (.*$)/gim, '<li>$1</li>')\n    .replace(/• (.*$)/gim, '<li>$1</li>');\n\n  // Wrap remaining lines as <p> except for already formatted tags\n  html = html\n    .split('\\n')\n    .map(line => {\n      if (/^\\s*<(h[2-3]|li)>/.test(line.trim())) return line;\n      if (line.trim() === '') return '';\n      return `<p>${line}</p>`;\n    })\n    .join('\\n');\n\n  return html;\n}\n\nconst formattedAIHtml = formatMarkdown(aiOutput);\n\n// HTML report structure\nconst htmlOutput = `\n<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body {\n      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n      line-height: 1.6;\n      color: #1a1a1a;\n      max-width: 700px;\n      margin: 0 auto;\n      padding: 20px;\n      background: #f5f5f5;\n    }\n    .container {\n      background: white;\n      border-radius: 12px;\n      overflow: hidden;\n      box-shadow: 0 4px 6px rgba(0,0,0,0.1);\n    }\n    .header {\n      background: linear-gradient(135deg, #1e3a5f 0%, #2d5a87 100%);\n      color: white;\n      padding: 30px;\n    }\n    .header h1 {\n      margin: 0 0 5px 0;\n      font-size: 28px;\n      font-weight: 700;\n    }\n    .header .tagline {\n      opacity: 0.9;\n      font-size: 14px;\n      margin-bottom: 15px;\n    }\n    .header .meta {\n      font-size: 14px;\n      opacity: 0.85;\n    }\n    .content {\n      padding: 30px;\n    }\n    .stats-grid {\n      display: grid;\n      grid-template-columns: repeat(2, 1fr);\n      gap: 15px;\n      margin: 20px 0;\n    }\n    .stat-card {\n      background: #f8fafc;\n      padding: 15px;\n      border-radius: 8px;\n      text-align: center;\n    }\n    .stat-card .number {\n      font-size: 24px;\n      font-weight: 700;\n      color: #2d5a87;\n    }\n    .stat-card .label {\n      font-size: 12px;\n      color: #666;\n      text-transform: uppercase;\n    }\n    .footer {\n      text-align: center;\n      color: #888;\n      font-size: 12px;\n      padding: 20px;\n      background: #f8fafc;\n      border-top: 1px solid #eee;\n    }\n    h2 { color: #1e3a5f; border-bottom: 2px solid #2d5a87; padding-bottom: 10px; }\n    h3 { color: #2d5a87; }\n    ul { padding-left: 20px; }\n    li { margin: 8px 0; }\n    strong { color: #1e3a5f; }\n    p { margin: 12px 0; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <h1>🎯 Executive Priority Alignment</h1>\n      <div class=\"tagline\">Daily Clarity. Zero Decision Fatigue.</div>\n      <div class=\"meta\">\n        📅 ${dateStr} &nbsp;|&nbsp; ⏰ ${timeStr} &nbsp;|&nbsp; 👤 ${config.executiveName}\n      </div>\n    </div>\n\n    <div class=\"content\">\n      <div class=\"stats-grid\">\n        <div class=\"stat-card\">\n          <div class=\"number\">${context.dayHealth?.meetingLoad || 0}h</div>\n          <div class=\"label\">Meeting Load</div>\n        </div>\n        <div class=\"stat-card\">\n          <div class=\"number\">${context.dayHealth?.availableFocusHours || 0}h</div>\n          <div class=\"label\">Focus Time</div>\n        </div>\n        <div class=\"stat-card\">\n          <div class=\"number\">${context.dayHealth?.pendingDecisions || 0}</div>\n          <div class=\"label\">Pending Decisions</div>\n        </div>\n        <div class=\"stat-card\">\n          <div class=\"number\">${context.dayHealth?.overdueItems || 0}</div>\n          <div class=\"label\">Overdue Items</div>\n        </div>\n      </div>\n\n      ${formattedAIHtml}\n    </div>\n\n    <div class=\"footer\">\n      <strong>📈 Data Sources Analyzed</strong><br>\n      Calendar: ${context.calendar?.summary?.totalEvents || 0} events &nbsp;|&nbsp;\n      Emails: ${context.emails?.summary?.totalEmails || 0} messages &nbsp;|&nbsp;\n      Tasks: ${context.tasks?.summary?.totalTasks || 0} items<br><br>\n      Generated by Executive Priority Alignment Automation™\n    </div>\n  </div>\n</body>\n</html>\n`;\n\n// Final output\nreturn [{\n  json: {\n    executiveName: config.executiveName,\n    executiveEmail: config.executiveEmail,\n    date: dateStr,\n    time: timeStr,\n    priorities: aiOutput,\n    prioritiesText: textOutput,\n    prioritiesHtml: htmlOutput,\n    metrics: {\n      meetingLoad: context.dayHealth?.meetingLoad || 0,\n      focusTime: context.dayHealth?.availableFocusHours || 0,\n      pendingDecisions: context.dayHealth?.pendingDecisions || 0,\n      overdueItems: context.dayHealth?.overdueItems || 0,\n      criticalItems: context.dayHealth?.criticalItems || 0\n    },\n    dataSources: {\n      calendarEvents: context.calendar?.summary?.totalEvents || 0,\n      emailsProcessed: context.emails?.summary?.totalEmails || 0,\n      tasksReviewed: context.tasks?.summary?.totalTasks || 0\n    }\n  }\n}];\n"
