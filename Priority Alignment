    {
      "parameters": {
        "jsCode": "// Process and categorize emails for priority analysis\nconst emails = $input.all();\n\nconst processedEmails = emails.map(item => {\n  const email = item.json;\n  const headers = email.payload?.headers || [];\n  \n  const getHeader = (name) => headers.find(h => h.name?.toLowerCase() === name.toLowerCase())?.value || '';\n  \n  const subject = getHeader('subject');\n  const from = getHeader('from');\n  const to = getHeader('to');\n  const date = email.internalDate ? new Date(parseInt(email.internalDate)) : new Date();\n  \n  // Extract sender name and domain\n  const senderMatch = from.match(/([^<]+)?<?([^>]+@([^>]+))>?/);\n  const senderName = (senderMatch?.[1] || '').trim() || from.split('@')[0];\n  const senderEmail = senderMatch?.[2] || from;\n  const senderDomain = senderMatch?.[3] || '';\n  \n  // Determine priority signals\n  const labelIds = email.labelIds || [];\n  const isStarred = labelIds.includes('STARRED');\n  const isImportant = labelIds.includes('IMPORTANT');\n  const isUnread = labelIds.includes('UNREAD');\n  \n  // Analyze subject for urgency\n  const subjectLower = subject.toLowerCase();\n  let urgencyLevel = 'normal';\n  let category = 'general';\n  \n  // Critical urgency indicators\n  if (subjectLower.includes('urgent') || subjectLower.includes('asap') || \n      subjectLower.includes('immediately') || subjectLower.includes('critical')) {\n    urgencyLevel = 'critical';\n  } else if (subjectLower.includes('important') || subjectLower.includes('action required') ||\n             subjectLower.includes('deadline') || subjectLower.includes('reminder')) {\n    urgencyLevel = 'high';\n  } else if (isImportant || isStarred) {\n    urgencyLevel = 'high';\n  }\n  \n  // Categorize email type\n  if (subjectLower.includes('approve') || subjectLower.includes('approval') || subjectLower.includes('sign')) {\n    category = 'approval-needed';\n  } else if (subjectLower.includes('decision') || subjectLower.includes('choose') || subjectLower.includes('option')) {\n    category = 'decision-needed';\n  } else if (subjectLower.includes('fyi') || subjectLower.includes('update') || subjectLower.includes('newsletter')) {\n    category = 'informational';\n  } else if (subjectLower.includes('question') || subjectLower.includes('help') || subjectLower.includes('request')) {\n    category = 'request';\n  } else if (subjectLower.includes('meeting') || subjectLower.includes('invite') || subjectLower.includes('calendar')) {\n    category = 'meeting-related';\n  } else if (subjectLower.includes('report') || subjectLower.includes('status') || subjectLower.includes('weekly')) {\n    category = 'report';\n  }\n  \n  return {\n    id: email.id,\n    threadId: email.threadId,\n    subject,\n    senderName,\n    senderEmail,\n    senderDomain,\n    snippet: email.snippet || '',\n    date: date.toISOString(),\n    dateFormatted: date.toLocaleString('en-US', {\n      weekday: 'short',\n      month: 'short',\n      day: 'numeric',\n      hour: 'numeric',\n      minute: '2-digit'\n    }),\n    isStarred,\n    isImportant,\n    isUnread,\n    urgencyLevel,\n    category,\n    requiresAction: ['approval-needed', 'decision-needed', 'request'].includes(category)\n  };\n});\n\n// Sort by urgency and filter actionable items\nconst urgencyOrder = { critical: 0, high: 1, normal: 2 };\nconst sortedEmails = processedEmails.sort((a, b) => \n  urgencyOrder[a.urgencyLevel] - urgencyOrder[b.urgencyLevel]\n);\n\nconst actionableEmails = sortedEmails.filter(e => e.requiresAction);\nconst criticalEmails = sortedEmails.filter(e => e.urgencyLevel === 'critical');\nconst highPriorityEmails = sortedEmails.filter(e => e.urgencyLevel === 'high');\n\nreturn [{\n  json: {\n    emails: sortedEmails,\n    actionableEmails,\n    summary: {\n      totalEmails: sortedEmails.length,\n      unreadCount: sortedEmails.filter(e => e.isUnread).length,\n      actionableCount: actionableEmails.length,\n      criticalCount: criticalEmails.length,\n      highPriorityCount: highPriorityEmails.length,\n      byCategory: {\n        approvalNeeded: sortedEmails.filter(e => e.category === 'approval-needed').length,\n        decisionNeeded: sortedEmails.filter(e => e.category === 'decision-needed').length,\n        requests: sortedEmails.filter(e => e.category === 'request').length\n      }\n    },\n    criticalEmails,\n    highPriorityEmails\n  }\n}];"
      },
