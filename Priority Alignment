    {
      "parameters": {
        "jsCode": "// Get all tasks from input\nconst tasks = $input.all();\nconst now = new Date();\nconst todayEnd = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 1);\nconst weekEnd = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 7);\n\n// Process each task\nconst processedTasks = tasks.map(item => {\n  const task = item.json;\n\n  // Parse due date (use either due_on or due_at)\n  let dueDate = null;\n  let isOverdue = false;\n  let isDueToday = false;\n  let isDueThisWeek = false;\n\n  if (task.due_on || task.due_at) {\n    dueDate = new Date(task.due_on || task.due_at);\n    isOverdue = dueDate < now;\n    isDueToday = dueDate < todayEnd && !isOverdue;\n    isDueThisWeek = dueDate < weekEnd && !isDueToday && !isOverdue;\n  }\n\n  // Analyze task title for priority signals\n  const title = (task.name || '').toLowerCase();\n  let prioritySignal = 'normal';\n  let category = 'general';\n\n  // Priority detection\n  if (isOverdue) {\n    prioritySignal = 'critical';\n  } else if (isDueToday) {\n    prioritySignal = 'high';\n  } else if (title.includes('urgent') || title.includes('critical') || title.includes('asap')) {\n    prioritySignal = 'critical';\n  } else if (title.includes('important') || title.includes('priority') || isDueThisWeek) {\n    prioritySignal = 'high';\n  }\n\n  // Category detection\n  if (title.includes('review') || title.includes('approve') || title.includes('sign')) {\n    category = 'approval';\n  } else if (title.includes('prepare') || title.includes('draft') || title.includes('write')) {\n    category = 'preparation';\n  } else if (title.includes('call') || title.includes('meet') || title.includes('discuss')) {\n    category = 'communication';\n  } else if (title.includes('decide') || title.includes('choose') || title.includes('finalize')) {\n    category = 'decision';\n  } else if (title.includes('follow up') || title.includes('check')) {\n    category = 'follow-up';\n  }\n\n  return {\n    id: task.gid,\n    title: task.name || 'Untitled Task',\n    assigneeId: task.assignee?.gid || null,\n    notes: task.notes || '',\n    dueDate: dueDate?.toISOString() || null,\n    dueDateFormatted: dueDate\n      ? dueDate.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' })\n      : 'No due date',\n    isOverdue,\n    isDueToday,\n    isDueThisWeek,\n    prioritySignal,\n    category,\n    status: task.completed ? 'Completed' : 'Pending',\n    link: task.permalink_url\n  };\n});\n\n// Sort tasks by priority, then due date\nconst priorityOrder = { critical: 0, high: 1, normal: 2 };\nconst sortedTasks = processedTasks.sort((a, b) => {\n  if (priorityOrder[a.prioritySignal] !== priorityOrder[b.prioritySignal]) {\n    return priorityOrder[a.prioritySignal] - priorityOrder[b.prioritySignal];\n  }\n  if (a.dueDate && b.dueDate) return new Date(a.dueDate) - new Date(b.dueDate);\n  if (a.dueDate) return -1;\n  if (b.dueDate) return 1;\n  return 0;\n});\n\n// Filter subsets for summary\nconst overdueTasks = sortedTasks.filter(t => t.isOverdue);\nconst todayTasks = sortedTasks.filter(t => t.isDueToday);\nconst criticalTasks = sortedTasks.filter(t => t.prioritySignal === 'critical');\n\nreturn [\n  {\n    json: {\n      tasks: sortedTasks,\n      summary: {\n        totalTasks: sortedTasks.length,\n        overdueCount: overdueTasks.length,\n        dueTodayCount: todayTasks.length,\n        dueThisWeekCount: sortedTasks.filter(t => t.isDueThisWeek).length,\n        criticalCount: criticalTasks.length,\n        highPriorityCount: sortedTasks.filter(t => t.prioritySignal === 'high').length\n      },\n      overdueTasks,\n      todayTasks,\n      criticalTasks\n    }\n  }\n];\n"
      },
